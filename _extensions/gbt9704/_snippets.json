{
  "GB/T 9704 PDF (XeLaTeX)": {
    "prefix": "gbt9704-pdf",
    "body": [
      "---",
      "title: ${1:关于印发<通知标题>的通知}",
      "header-org: ${2:XX单位办公室}",
      "header-number: ${3:XX发〔202X〕X号}",
      "mainreceiver: ${4:各有关单位：}",
      "signature: ${5:XX单位办公室}",
      "signdate: ${6:202X年X月X日}",
      "emoji: true",
      "format:",
      "  gbt9704-pdf:",
      "    keep-tex: true",
      "    classoption:",
      "      - redline",
      "      - zhlineskip",
      "---",
      "",
      "${0}"
    ],
    "description": "GB/T 9704 PDF 文档（红头文件，XeLaTeX 引擎）"
  },
